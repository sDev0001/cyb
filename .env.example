# ================================================================
# Application
# ================================================================
DOMAIN=https://your-app.example.com
PORT=3000

# ================================================================
# CYBERSOURCE CONFIGURATION
# Sandbox: apitest.cybersource.com
# Production: api.cybersource.com
# ================================================================
CYBERSOURCE_BASE_URL=https://apitest.cybersource.com
CYBERSOURCE_RUN_ENVIRONMENT=apitest.cybersource.com
CYBERSOURCE_AUTH_TYPE=http_signature

# Credentials from CyberSource Business Center > Key Management > HTTP Signature
CYBERSOURCE_MERCHANT_ID=your_merchant_id
CYBERSOURCE_MERCHANT_KEY_ID=your_key_uuid
CYBERSOURCE_MERCHANT_SECRET_KEY=your_secret_key_base64

# JWT-based auth (only if CYBERSOURCE_AUTH_TYPE=jwt)
CYBERSOURCE_KEY_ALIAS=your_merchant_id
CYBERSOURCE_KEY_PASS=your_key_pass
CYBERSOURCE_KEY_FILE_NAME=your_merchant_id
CYBERSOURCE_KEYS_DIRECTORY=Resource

# Logging
CYBERSOURCE_LOG_FILE_MAX_SIZE=5242880
CYBERSOURCE_LOGGING_LEVEL=debug
CYBERSOURCE_ENABLE_MASKING=true

# Partner identifiers (request these from CyberSource or leave defaults for sandbox)
CYBERSOURCE_PARTNER_DEVELOPER_ID=7891234
CYBERSOURCE_PARTNER_SOLUTION_ID=89012345
